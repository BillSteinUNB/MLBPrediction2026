.env
.venv/
venv/
env/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
data/*.db
*.db-wal
*.db-shm
